# ============================================================
# LAVAI — Environment Variables (.env.example)
# ============================================================
# Copie para .env.local e preencha. Variáveis com NEXT_PUBLIC_*
# são expostas ao browser. As demais ficam apenas no servidor.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LAVAI

# ── Demo mode (dev/preview/demonstração) ─────────────────────
# Em produção, demo SÓ ativa com 'true' explícito.
# Em dev, demo ativa automaticamente quando Supabase não está configurado.
NEXT_PUBLIC_LAVAI_DEMO_ENABLED=false

# ── Supabase ─────────────────────────────────────────────────
# Deixe NEXT_PUBLIC_SUPABASE_URL vazio (ou com "seu-projeto") para
# rodar em modo demo em desenvolvimento.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Asaas (pagamentos BR — PIX/Cartão/Boleto) ────────────────
ASAAS_API_KEY=your_asaas_api_key
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=your_webhook_token

# ── Resend (emails transacionais) ────────────────────────────
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=no-reply@lavai.com.br

# ── Anthropic (AI Insights) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Z-API (WhatsApp Bot) ─────────────────────────────────────
# Credenciais globais (fallback). Cada lava-jato tem suas próprias
# em whatsapp_config.
ZAPI_INSTANCE_ID=your_instance_id
ZAPI_TOKEN=your_token
ZAPI_CLIENT_TOKEN=your_client_token

# ── Web Push VAPID ───────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ── Cron jobs ────────────────────────────────────────────────
CRON_SECRET=your_cron_secret

# ── Upstash Redis (rate limit + cache distribuído — task #11) ─
# Free tier: 10k req/dia. Get at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (error tracking — task #12) ───────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── PostHog (product analytics — task #13) ───────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── HMAC secret (NPS signed links — task #8) ─────────────────
NPS_HMAC_SECRET=

# ── Cloudflare Turnstile (CAPTCHA — task #9) ─────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
