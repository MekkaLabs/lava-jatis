# LAVAI Environment Variables
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LAVAI

# Database (future)
# DATABASE_URL=postgresql://...

# Auth (future)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# WhatsApp Bot — Z-API (https://z-api.io)
# Used as fallback global credentials; per-lava-jato credentials are stored in whatsapp_config table
ZAPI_INSTANCE_ID=your_instance_id
ZAPI_TOKEN=your_token
ZAPI_CLIENT_TOKEN=your_client_token

# AI — Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Asaas — Pagamentos (https://asaas.com)
ASAAS_API_KEY=your_asaas_api_key
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=your_webhook_token

# Resend — Email transacional (https://resend.com)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=no-reply@lavai.com.br

# Cron secret — protege endpoints de cron job
CRON_SECRET=your_cron_secret

# VAPID keys — Web Push PWA (gerar com: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
